{
  "name": "recaptcha-vue",
  "version": "1.0.0",
  "description": "Lightweight Vue 3 reCAPTCHA v2 checkbox component with TypeScript, Vite library build, and Inertia.js support",
  "author": "Souhail Makni <maknisouhail@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Souhailmakni/recaptcha-vue.git"
  },
  "homepage": "https://github.com/Souhailmakni/recaptcha-vue#readme",
  "bugs": {
    "url": "https://github.com/Souhailmakni/recaptcha-vue/issues"
  },
  "keywords": [
    "vue3",
    "vue",
    "recaptcha",
    "recaptcha-v2",
    "checkbox",
    "google-recaptcha",
    "inertia",
    "laravel",
    "vite",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/recaptcha-vue.umd.cjs",
  "module": "./dist/recaptcha-vue.js",
  "exports": {
    ".": {
      "import": "./dist/recaptcha-vue.js",
      "require": "./dist/recaptcha-vue.umd.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --ext .ts,.vue --fix",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
